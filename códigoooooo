import discord, random, os
from discord.ext import commands

description = "pede alguma cois ai q eu tento te ajudar"

intents = discord.Intents.default()
intents.members = True
intents.message_content = True

bot = commands.Bot(command_prefix='$', description=description, intents=intents)


@bot.event
async def on_ready():
    assert bot.user is not None
    print(f'{bot.user} online.')
    print('------')


@bot.command()
async def soma(ctx, left: int, right: int):
    resultado = left + right
    await ctx.send(f"{left} + {right} = {resultado}. tranquilo.")


@bot.command()
async def decide(ctx, *choices: str):
    if not choices:
        await ctx.send("tu precisa me dar opção né.")
        return

    escolha = random.choice(choices)
    await ctx.send(f"vai nesse aqui: **{escolha}**.")


@bot.command()
async def entrou(ctx, member: discord.Member):
    if member.joined_at is None:
        await ctx.send(f"{member} entrou... eu acho.")
    else:
        await ctx.send(f"{member} entrou em {discord.utils.format_dt(member.joined_at)}.")


