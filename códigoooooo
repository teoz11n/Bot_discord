@bot.command()
async def banho(ctx):

    await ctx.send("🚿 quanto tempo dura teu banho? (responde só com o número em minutos)")

    def check(m):
        return m.author == ctx.author and m.channel == ctx.channel



    try:
        msg = await bot.wait_for("message", check=check, timeout=30)
        minutos = int(msg.content)

        agua = minutos * 9
        await ctx.send(
            f"🚿 tu fica {minutos} minutos no banho.\n\n" f"isso gasta mais ou menos **{agua} litros de água**.\n\n"
            "se diminuir uns minutos já economiza bastante água 🌱"
        )

    except:
        await ctx.send("demorou muito pra responder ou mandou algo que não é número 💀 tenta dnv.")









